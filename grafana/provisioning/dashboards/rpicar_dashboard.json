      "title": "🔋 Power — Battery Voltage & Current",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" }, "rawQuery": true, "query": "SELECT mean(\"battery_voltage\") FROM \"rpicar_power\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "refId": "A", "alias": "battery_voltage", "resultFormat": "time_series" },
