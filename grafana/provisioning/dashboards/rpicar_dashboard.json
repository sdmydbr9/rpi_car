      "noValue": "--",
      "title": "⚡ Current Draw",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" }, "rawQuery": true, "query": "SELECT last(\"current_amps\") FROM \"rpicar_power\" WHERE time > now() - 10s", "refId": "A", "resultFormat": "time_series" }]
    },

    {
      "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" },
