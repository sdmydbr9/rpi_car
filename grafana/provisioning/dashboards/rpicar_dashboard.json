      "noValue": "--",
      "title": "🏎️  Speed (m/s)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" }, "rawQuery": true, "query": "SELECT last(\"speed_mpm\") FROM \"rpicar_drive\" WHERE time > now() - 10s", "refId": "A", "resultFormat": "time_series" }]
    },

    {
      "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
