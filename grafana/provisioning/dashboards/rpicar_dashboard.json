      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 10.5 },
            { "color": "yellow", "value": 11.0 },
            { "color": "green", "value": 11.5 }
          ]},
          "unit": "volt", "min": 9, "max": 12.6
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "noValue": "--",
      "title": "🔋 Battery Voltage",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" }, "rawQuery": true, "query": "SELECT last(\"battery_voltage\") FROM \"rpicar_power\" WHERE time > now() - 10s", "refId": "A", "resultFormat": "time_series" }]
    },

    {
      "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" },
