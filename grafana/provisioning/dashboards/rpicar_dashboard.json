      "datasource": { "type": "influxdb", "uid": "influxdb-rpicar" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "volt", "color": { "mode": "fixed", "fixedColor": "green" } },
