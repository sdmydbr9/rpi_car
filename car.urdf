  <gazebo reference="camera">
    <material>Gazebo/Black</material>
    <sensor name="camera_sensor" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>100.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>1</visualize>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=camera/image_raw</remapping>
          <remapping>~/camera_info:=camera/camera_info</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <link name="laser_scanner">
    <inertial>
      <mass value="0.006"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.014 0.012 0.008"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.014 0.012 0.008"/>
      </geometry>
      <material name="sensor_red"/>
    </visual>
    <visual>
      <origin xyz="0.008 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.003" length="0.004"/>
      </geometry>
      <material name="heatsink_silver"/>
    </visual>
  </link>

  <joint name="laser_scanner_joint" type="fixed">
    <parent link="camera_tilt_link"/>
    <child link="laser_scanner"/>
    <origin xyz="0.024 -0.017 0.008" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser_scanner">
    <material>Gazebo/Red</material>
    <sensor name="laser_scanner_sensor" type="ray">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>15</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.03</min>
          <max>2.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </ray>
      <plugin name="laser_scanner_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>laser_scanner</frame_name>
        <radiation_type>infrared</radiation_type>
        <fov>0.0349</fov>
        <min_range>0.03</min_range>
        <max_range>2.0</max_range>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== ACTIVE SENSOR BOARDS ===== -->
  <link name="imu">
    <inertial>
      <mass value="0.008"/>
      <origin xyz="0 0 0.004"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.008"/>
      </geometry>
      <material name="pcb_blue"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu"/>
    <origin xyz="0.008 0 0.067" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu">
    <material>Gazebo/Blue</material>
    <sensor name="imu_sensor" type="imu">
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>0</initial_orientation_as_reference>
      </plugin>
      <always_on>1</always_on>
      <update_rate>50</update_rate>
      <visualize>0</visualize>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <link name="ads1115_power_monitor">
    <inertial>
      <mass value="0.010"/>
      <origin xyz="0 0 0.004"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.028 0.018 0.008"/>
      </geometry>
      <material name="pcb_blue"/>
    </visual>
  </link>

  <joint name="ads1115_power_monitor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ads1115_power_monitor"/>
    <origin xyz="0.060 0.040 0.012" rpy="0 0 0"/>
  </joint>

  <link name="battery_voltage_sensor">
    <inertial>
      <mass value="0.0001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="battery_voltage_sensor_joint" type="fixed">
    <parent link="ads1115_power_monitor"/>
    <child link="battery_voltage_sensor"/>
    <origin xyz="0.006 0 0.004" rpy="0 0 0"/>
  </joint>

  <link name="current_sensor">
    <inertial>
      <mass value="0.0001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="current_sensor_joint" type="fixed">
    <parent link="ads1115_power_monitor"/>
    <child link="current_sensor"/>
    <origin xyz="-0.006 0 0.004" rpy="0 0 0"/>
  </joint>

  <!-- Three encoder modules are present in the live system. Front-left is intentionally absent. -->
  <link name="encoder_rear_left">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.012 0.010"/>
      </geometry>
      <material name="sensor_red"/>
    </visual>
  </link>

  <joint name="encoder_rear_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="encoder_rear_left"/>
    <origin xyz="-0.098 0.058 0.002" rpy="0 0 0"/>
  </joint>

  <link name="encoder_rear_right">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.012 0.010"/>
      </geometry>
      <material name="sensor_red"/>
    </visual>
  </link>

  <joint name="encoder_rear_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="encoder_rear_right"/>
    <origin xyz="-0.098 -0.058 0.002" rpy="0 0 0"/>
  </joint>

  <link name="encoder_front_right">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.012 0.010"/>
      </geometry>
      <material name="sensor_red"/>
    </visual>
  </link>

  <joint name="encoder_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="encoder_front_right"/>
    <origin xyz="0.098 -0.058 0.002" rpy="0 0 0"/>
  </joint>

  <!-- ===== TRANSMISSIONS (rear drive only — front wheels are passive) ===== -->
  <transmission name="wheel_rear_left_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_rear_left_joint">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_rear_left">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
      <mechanicalReduction>30.0</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="wheel_rear_right_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wheel_rear_right_joint">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor_rear_right">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
      <mechanicalReduction>30.0</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ===== GAZEBO ACKERMANN DRIVE PLUGIN =====
       Matches physical hardware: LD-1501MG steering servo,
       2WD rear encoder-geared motors, wheelbase 0.210m, track 0.172m. -->
  <gazebo>
    <plugin filename="libgazebo_ros_ackermann_drive.so" name="ackermann_drive_controller">
      <ros>
        <namespace></namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100</update_rate>
      <left_steering_joint>steering_knuckle_left_joint</left_steering_joint>
      <right_steering_joint>steering_knuckle_right_joint</right_steering_joint>
      <left_rear_joint>wheel_rear_left_joint</left_rear_joint>
      <right_rear_joint>wheel_rear_right_joint</right_rear_joint>
      <left_front_joint>wheel_front_left_joint</left_front_joint>
      <right_front_joint>wheel_front_right_joint</right_front_joint>
      <steering_limit>0.5236</steering_limit>
      <wheel_separation>0.172</wheel_separation>
      <wheelbase>0.210</wheelbase>
      <wheel_diameter>0.075</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odometry_source>world</odometry_source>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
  </gazebo>

</robot>
