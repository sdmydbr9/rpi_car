<?xml version="1.0"?>
<!--
  URDF for the current Raspberry Pi rover build.

  Chassis: Hiwonder Ackermann Metal Chassis
           (anodized aluminium frame, 2WD rear encoder-geared motors,
            LD-1501MG high-precision Ackermann front steering servo,
            solid rubber tyres ×4)

  Notes
  - Updated to match the Hiwonder Ackermann metal chassis layout.
  - The old rear HC-SR04 sonar has been removed from the model because the
    live system now aliases "sonar" calls to the forward VL53L0X laser.
  - Added explicit frames / visuals for the active hardware stack:
      * Pi camera on pan/tilt gimbal
      * VL53L0X forward ToF laser
      * MPU6500 IMU
      * QMC5883L magnetometer on the elevated left mast
      * ADS1115 power monitor (battery + current telemetry)
      * LM393 wheel encoders on RL / RR / FR wheels
-->

<robot name="rpi_rc_car">

  <!-- ===== MATERIALS ===== -->
  <material name="anodized_metal">
    <color rgba="0.22 0.22 0.24 1.0"/>
  </material>
  <material name="metal_standoff">
    <color rgba="0.70 0.70 0.72 1.0"/>
  </material>
  <material name="tire_rubber">
    <color rgba="0.12 0.12 0.12 1.0"/>
  </material>
  <material name="wheel_hub_red">
    <color rgba="0.72 0.12 0.12 1.0"/>
  </material>
  <material name="pcb_green">
    <color rgba="0.15 0.45 0.16 1.0"/>
  </material>
  <material name="pcb_blue">
    <color rgba="0.11 0.46 0.83 1.0"/>
  </material>
  <material name="pcb_black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="sensor_red">
    <color rgba="0.88 0.18 0.16 1.0"/>
  </material>
  <material name="sensor_cyan">
    <color rgba="0.18 0.72 0.80 1.0"/>
  </material>
  <material name="heatsink_silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>
  <material name="metal_light">
    <color rgba="0.86 0.86 0.88 1.0"/>
  </material>
  <material name="connector_white">
    <color rgba="0.94 0.94 0.90 1.0"/>
  </material>
  <material name="header_black">
    <color rgba="0.18 0.16 0.14 1.0"/>
  </material>
  <material name="fan_clear">
    <color rgba="0.86 0.92 0.96 0.45"/>
  </material>
  <material name="rgb_ring">
    <color rgba="0.18 0.72 0.95 0.65"/>
  </material>
  <material name="copper_pin">
    <color rgba="0.72 0.47 0.24 1.0"/>
  </material>
  <material name="battery_green">
    <color rgba="0.24 0.80 0.25 1.0"/>
  </material>
  <material name="bumper_red">
    <color rgba="0.82 0.10 0.08 1.0"/>
  </material>
  <material name="bumper_black">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>
  <material name="metal_dark">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>

  <!-- ===== BASE FRAMES ===== -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.0001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0375" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="3.5"/>
      <origin xyz="0 0 0.045"/>
      <inertia ixx="0.045" ixy="0" ixz="0" iyy="0.065" iyz="0" izz="0.090"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.295 0.172 0.090"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== MAIN CHASSIS / ANODIZED METAL PLATES (Hiwonder Ackermann) ===== -->
  <link name="lower_deck">
    <inertial>
      <mass value="0.28"/>
      <origin xyz="0 0 0.0015"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0030" iyz="0" izz="0.0040"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.0015" rpy="0 0 0"/>
      <geometry>
        <box size="0.295 0.148 0.003"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0.0015" rpy="0 0 0"/>
      <geometry>
        <box size="0.295 0.148 0.003"/>
      </geometry>
      <material name="anodized_metal"/>
    </visual>
  </link>

  <joint name="lower_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lower_deck"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="upper_deck">
    <inertial>
      <mass value="0.16"/>
      <origin xyz="0 0 0.0015"/>
      <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0016"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.0015" rpy="0 0 0"/>
      <geometry>
        <box size="0.245 0.130 0.003"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0.0015" rpy="0 0 0"/>
      <geometry>
        <box size="0.245 0.130 0.003"/>
      </geometry>
      <material name="anodized_metal"/>
    </visual>
  </link>

  <joint name="upper_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="upper_deck"/>
    <origin xyz="-0.010 0 0.043" rpy="0 0 0"/>
  </joint>

  <link name="deck_standoffs">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.020"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0.095 0.050 0.020" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.003" length="0.040"/>
      </geometry>
      <material name="metal_standoff"/>
    </visual>
    <visual>
      <origin xyz="0.095 -0.050 0.020" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.003" length="0.040"/>
      </geometry>
      <material name="metal_standoff"/>
    </visual>
    <visual>
      <origin xyz="-0.095 0.050 0.020" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.003" length="0.040"/>
      </geometry>
      <material name="metal_standoff"/>
    </visual>
    <visual>
      <origin xyz="-0.095 -0.050 0.020" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.003" length="0.040"/>
      </geometry>
      <material name="metal_standoff"/>
    </visual>
  </link>

  <joint name="deck_standoffs_joint" type="fixed">
    <parent link="base_link"/>
    <child link="deck_standoffs"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="front_bumper">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0.006"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.032 0.070 0.012"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.032 0.070 0.012"/>
      </geometry>
      <material name="bumper_black"/>
    </visual>
    <visual>
      <origin xyz="0.004 0 0.011" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.090 0.006"/>
      </geometry>
      <material name="bumper_red"/>
    </visual>
  </link>

  <joint name="front_bumper_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_bumper"/>
    <origin xyz="0.160 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===== WHEELS (75mm dia × 28mm wide, red multi-spoke hubs) ===== -->
  <link name="wheel_front_left">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0014"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
      <material name="tire_rubber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.029"/>
      </geometry>
      <material name="wheel_hub_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.030"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
  </link>

  <!-- Ackermann steering: knuckle (revolute around Z) holds the wheel (continuous around Y) -->
  <link name="steering_knuckle_left">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="steering_knuckle_left_joint" type="revolute">
    <parent link="base_link"/>
    <child link="steering_knuckle_left"/>
    <origin xyz="0.105 0.086 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5236" upper="0.5236" effort="5.0" velocity="3.0"/>
  </joint>

  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="steering_knuckle_left"/>
    <child link="wheel_front_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" velocity="20.0"/>
  </joint>

  <link name="wheel_front_right">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0014"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
      <material name="tire_rubber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.029"/>
      </geometry>
      <material name="wheel_hub_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.030"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
  </link>

  <link name="steering_knuckle_right">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="steering_knuckle_right_joint" type="revolute">
    <parent link="base_link"/>
    <child link="steering_knuckle_right"/>
    <origin xyz="0.105 -0.086 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5236" upper="0.5236" effort="5.0" velocity="3.0"/>
  </joint>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="steering_knuckle_right"/>
    <child link="wheel_front_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" velocity="20.0"/>
  </joint>

  <link name="wheel_rear_left">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0014"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
      <material name="tire_rubber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.029"/>
      </geometry>
      <material name="wheel_hub_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.030"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
  </link>

  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_left"/>
    <origin xyz="-0.105 0.086 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" velocity="20.0"/>
  </joint>

  <link name="wheel_rear_right">
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0014"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.028"/>
      </geometry>
      <material name="tire_rubber"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.029"/>
      </geometry>
      <material name="wheel_hub_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.030"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
  </link>

  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_right"/>
    <origin xyz="-0.105 -0.086 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" velocity="20.0"/>
  </joint>

  <gazebo reference="wheel_front_left">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel_front_right">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel_rear_left">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel_rear_right">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>

  <!-- ===== STEERING SERVO (LD-1501MG, under front of chassis) ===== -->
  <link name="steering_servo">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.040 0.020 0.036"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.006" length="0.008"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
  </link>

  <joint name="steering_servo_joint" type="fixed">
    <parent link="base_link"/>
    <child link="steering_servo"/>
    <origin xyz="0.080 0 -0.018" rpy="0 0 0"/>
  </joint>

  <!-- ===== REAR DRIVE MOTOR + GEARBOX ===== -->
  <link name="rear_motor_gearbox">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.070"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="-0.022 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <box size="0.028 0.028 0.050"/>
      </geometry>
      <material name="metal_dark"/>
    </visual>
  </link>

  <joint name="rear_motor_gearbox_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_motor_gearbox"/>
    <origin xyz="-0.105 0 -0.008" rpy="0 0 0"/>
  </joint>

  <!-- ===== ELECTRONICS / VISUAL HARDWARE ===== -->
  <link name="raspberry_pi">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.005"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00008"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.085 0.056 0.010"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0.0016" rpy="0 0 0"/>
      <geometry>
        <box size="0.085 0.056 0.0032"/>
      </geometry>
      <material name="pcb_green"/>
    </visual>
    <visual>
      <origin xyz="-0.011 0.011 0.0048" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.0064"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
    <visual>
      <origin xyz="-0.004 0.004 0.0056" rpy="0 0 0"/>
      <geometry>
        <box size="0.028 0.028 0.008"/>
      </geometry>
      <material name="heatsink_silver"/>
    </visual>
    <visual>
      <origin xyz="-0.004 0.004 0.0114" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.030 0.0012"/>
      </geometry>
      <material name="heatsink_silver"/>
    </visual>
    <visual>
      <origin xyz="-0.004 -0.0195 0.0052" rpy="0 0 0"/>
      <geometry>
        <box size="0.052 0.005 0.0072"/>
      </geometry>
      <material name="header_black"/>
    </visual>
    <visual>
      <origin xyz="-0.004 -0.0195 0.0094" rpy="0 0 0"/>
      <geometry>
        <box size="0.050 0.003 0.0016"/>
      </geometry>
      <material name="wheel_hub_yellow"/>
    </visual>
    <visual>
      <origin xyz="0.032 0.014 0.0085" rpy="0 0 0"/>
      <geometry>
        <box size="0.021 0.016 0.014"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="0.033 -0.002 0.0068" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.015 0.010"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="0.033 -0.017 0.0068" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.015 0.010"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="-0.033 0.015 0.0048" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.012 0.006"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="-0.033 0.002 0.0042" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.010 0.0048"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="-0.033 -0.008 0.0042" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.010 0.0048"/>
      </geometry>
      <material name="metal_light"/>
    </visual>
    <visual>
      <origin xyz="-0.033 -0.020 0.0046" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0035" length="0.006"/>
      </geometry>
      <material name="pcb_black"/>
    </visual>
    <visual>
      <origin xyz="-0.020 0.021 0.0042" rpy="0 0 0"/>
      <geometry>
        <box size="0.022 0.004 0.004"/>
      </geometry>
      <material name="connector_white"/>
    </visual>
    <visual>
      <origin xyz="-0.020 -0.021 0.0042" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.004 0.004"/>
      </geometry>
      <material name="connector_white"/>
    </visual>
  </link>

  <joint name="raspberry_pi_joint" type="fixed">
    <parent link="base_link"/>
    <child link="raspberry_pi"/>
    <origin xyz="0.050 0 0.047" rpy="0 0 1.5708"/>
  </joint>

  <link name="heatsink">
    <inertial>
      <mass value="0.18"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry>
        <box size="0.038 0.038 0.060"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="-0.004 0 0.030" rpy="0 0 0"/>
      <geometry>
        <box size="0.022 0.032 0.052"/>
      </geometry>
      <material name="heatsink_silver"/>
    </visual>
    <visual>
      <origin xyz="-0.015 0 0.030" rpy="0 0 0"/>
      <geometry>
        <box size="0.0025 0.030 0.052"/>
      </geometry>
